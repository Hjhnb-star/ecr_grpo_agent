{
  "experiment_name": "hf_lora_synthetic_placeholder",
  "output_dir": "runs/hf_lora_synthetic",
  "seed": 7,
  "environment": {
    "name": "synthetic",
    "num_tasks": 24,
    "max_steps": 8,
    "sequences": [
      ["find_key", "open_box", "read_code", "submit_code"],
      ["search_web", "extract_fact", "verify_fact", "answer"]
    ],
    "action_space": [
      "find_key",
      "open_box",
      "read_code",
      "submit_code",
      "search_web",
      "extract_fact",
      "verify_fact",
      "answer",
      "wait",
      "distractor"
    ]
  },
  "async": {
    "enabled": true,
    "delay_prob": 0.3,
    "max_delay_steps": 3,
    "timeout_prob": 0.08,
    "interruption_prob": 0.03,
    "missing_reward_prob": 0.08,
    "terminal_reward_delay": 2
  },
  "credit": {
    "kernel": "dependency",
    "lambda": 0.35,
    "max_pending_age": 8,
    "timeout_penalty": -0.25,
    "tool_match_bonus": 1.5,
    "subgoal_match_bonus": 2.0
  },
  "policy": {
    "kind": "hf_lora",
    "model_id": "REPLACE_WITH_HF_MODEL_ID_OR_LOCAL_PATH",
    "adapter_path": null,
    "use_lora": true,
    "lora_r": 8,
    "lora_alpha": 16,
    "lora_dropout": 0.05,
    "device": null,
    "max_new_tokens": 8,
    "temperature": 0.7,
    "top_p": 1.0
  },
  "training": {
    "num_updates": 20,
    "tasks_per_update": 2,
    "group_size": 2,
    "learning_rate": 5.0e-6,
    "clip_eps": 0.2,
    "grad_accum_steps": 4
  },
  "evaluation": {
    "every_updates": 5,
    "num_eval_tasks": 12,
    "delay_sweep": [0.0, 0.3, 0.6]
  }
}

